<Window x:Class="FileMappingEngine.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FileMappingEngine"
        mc:Ignorable="d"
        Title="File Mapper" Height="500" Width="1000">
    <Grid>
        <DockPanel LastChildFill="True">
            <StackPanel x:Name="mappingPanel" Width="80"/>
            <ToolBar DockPanel.Dock="Top" Height="41" Padding="5">
                <TextBox Name="txtFilePath" HorizontalAlignment="Left" TextWrapping="Wrap" Text="Choose File" VerticalAlignment="Top" Width="200"/>
                <Button Name="ChooseFileButton" Content="Open File" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="5,0,20,0" Click="ChooseFileButton_Click"/>
                <StackPanel Name="headerRowPanel" Orientation="Horizontal" VerticalAlignment="Top" IsEnabled="False">
                    <Label Content="Header row"/>
                    <ComboBox Name="CbHeaderRow" Margin="5,0,0,0" Width="40" SelectionChanged="CbHeaderRow_SelectionChanged"/>
                </StackPanel>
                <Button Name="SaveFileButton" Content="Save File" VerticalAlignment="Top" Margin="20,0,20,0" Click="SaveFileButton_Click"/>
                <Button Name="SaveMapping" Content="Save new mapping set" VerticalAlignment="Top" Margin="20,0,20,0" Click="SaveMappingSet_Click"/>
                <Button Name="ResetTable" Content="Reset Table" VerticalAlignment="Top" Margin="20,0,20,0" Click="ResetTable_Click"/>
                <Button Name="Undo" Content="Undo" VerticalAlignment="Top" Margin="20,0,20,0" Click="Undo_Click"/>

            </ToolBar>
            <Grid>
                <DataGrid Name="dataGrid"
                  AutoGenerateColumns="True"
                  CanUserSortColumns="True"
                  HeadersVisibility="Column"
                  Margin="5"
                  Sorting="OnDataGridSorting_Sorting"
                  AutoGeneratingColumn="DataGrid_AutoGeneratingColumn"/>
            </Grid>
        </DockPanel>
        <Grid x:Name="RenameColumnOverlay"
      Background="#AA000000"
      Visibility="Collapsed">

            <Border HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Padding="30"
            Background="White"
            Width="450">

                <StackPanel>

                    <!-- Virsraksts -->
                    <TextBlock Text="Rename Column"
                       FontSize="24"
                       FontWeight="Bold"
                       Margin="0,0,0,20"
                       HorizontalAlignment="Center"/>

                    <!-- Pašreizējais nosaukums -->
                    <TextBlock Text="Current column name:"
                       Margin="0,0,0,5"/>

                    <TextBlock x:Name="txtCurrentColumnName"
                       FontWeight="Bold"
                       Margin="0,0,0,20"/>

                    <!-- Jaunais nosaukums -->
                    <TextBlock Text="New column name:"
                       Margin="0,0,0,5"/>

                    <TextBox x:Name="txtNewColumnName"
                     Height="30"
                     Margin="0,0,0,10"/>

                    <!-- Validācijas teksts -->
                    <TextBlock x:Name="txtRenameValidation"
                       Foreground="Red"
                       Visibility="Collapsed"
                       Margin="0,0,0,15"/>

                    <!-- Pogas -->
                    <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center">

                        <Button Content="Save"
                        Width="100"
                        Margin="5"
                        Click="SaveRenameColumn_Click"/>

                        <Button Content="Cancel"
                        Width="100"
                        Margin="5"
                        Click="CancelRenameColumn_Click"/>

                    </StackPanel>

                </StackPanel>

            </Border>

        </Grid>
        <Grid x:Name="MergeColumnsOverlay"
      Background="#AA000000"
      Visibility="Collapsed">

            <Border HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Padding="30"
            Background="White"
            Width="450">

                <StackPanel>

                    <!-- Virsraksts -->
                    <TextBlock Text="Merge Columns"
                       FontSize="24"
                       FontWeight="Bold"
                       Margin="0,0,0,20"
                       HorizontalAlignment="Center"/>

                    <!-- Pirmā kolonna -->
                    <TextBlock Text="First column:"
                       Margin="0,0,0,5"/>

                    <ComboBox x:Name="cmbMergeColumn1"
                      Height="30"
                      Margin="0,0,0,15"/>

                    <!-- Atdalītājs -->
                    <TextBlock Text="Separator:"
                       Margin="0,0,0,5"/>

                    <TextBox x:Name="txtMergeSeparator"
                     Height="30"
                     Margin="0,0,0,15"
                     Text=" "/>

                    <!-- Otrā kolonna -->
                    <TextBlock Text="Second column:"
                       Margin="0,0,0,5"/>

                    <ComboBox x:Name="cmbMergeColumn2"
                      Height="30"
                      Margin="0,0,0,15"/>

                    <!-- Jaunās kolonnas nosaukums -->
                    <TextBlock Text="Result column name:"
                       Margin="0,0,0,5"/>

                    <TextBox x:Name="txtMergeResultColumn"
                     Height="30"
                     Margin="0,0,0,10"/>

                    <!-- Validācijas teksts -->
                    <TextBlock x:Name="txtMergeValidation"
                       Foreground="Red"
                       Visibility="Collapsed"
                       Margin="0,0,0,15"/>

                    <!-- Pogas -->
                    <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center">

                        <Button Content="Save"
                        Width="100"
                        Margin="5"
                        Click="SaveMergeColumns_Click"/>

                        <Button Content="Cancel"
                        Width="100"
                        Margin="5"
                        Click="CancelMergeColumns_Click"/>

                    </StackPanel>

                </StackPanel>

            </Border>

        </Grid>
        <Grid x:Name="ChangeDataTypeOverlay"
      Background="#AA000000"
      Visibility="Collapsed">

            <Border HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Padding="30"
            Background="White"
            Width="450">

                <StackPanel>

                    <!-- Virsraksts -->
                    <TextBlock Text="Change Data Type"
                       FontSize="24"
                       FontWeight="Bold"
                       Margin="0,0,0,20"
                       HorizontalAlignment="Center"/>


                    <!-- Kolonna -->
                    <TextBlock Text="Column:"
                       Margin="0,0,0,5"/>

                    <TextBlock x:Name="txtDataTypeColumn"
                        Text=""
                        Margin="0,0,0,5"/>


                    <!-- Data tips -->
                    <TextBlock Text="New data type:"
                       Margin="0,0,0,5"/>

                    <ComboBox x:Name="cmbDataType"
                      Height="30"
                      Margin="0,0,0,15"/>


                    <!-- Brīdinājums -->
                    <TextBlock x:Name="txtDataTypeWarning"
                       Text="Changing data type may affect existing values."
                       Foreground="DarkOrange"
                       Visibility="Collapsed"
                       Margin="0,0,0,15"/>


                    <!-- Validācija -->
                    <TextBlock x:Name="txtDataTypeValidation"
                       Foreground="Red"
                       Visibility="Collapsed"
                       Margin="0,0,0,15"/>


                    <!-- Pogas -->
                    <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center">

                        <Button Content="Save"
                        Width="100"
                        Margin="5"
                        Click="SaveDataType_Click"/>


                        <Button Content="Cancel"
                        Width="100"
                        Margin="5"
                        Click="CancelDataType_Click"/>

                    </StackPanel>

                </StackPanel>

            </Border>

        </Grid>
        <Grid x:Name="SaveMappingOverlay"
      Background="#AA000000"
      Visibility="Collapsed">

            <Border HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Padding="30"
            Background="White"
            Width="500">

                <StackPanel>

                    <!-- Virsraksts -->
                    <TextBlock Text="Save Mapping"
                       FontSize="24"
                       FontWeight="Bold"
                       Margin="0,0,0,20"
                       HorizontalAlignment="Center"/>

                    <!-- File Definition -->
                    <TextBlock Text="File definition name:"
                       Margin="0,0,0,5"/>

                    <TextBox x:Name="txtFileDefinitionName"
                     Height="30"
                     Margin="0,0,0,15"/>

                    <!-- Mapping -->
                    <TextBlock Text="Mapping name:"
                       Margin="0,0,0,5"/>

                    <TextBox x:Name="txtMappingName"
                     Height="30"
                     Margin="0,0,0,15"/>

                    <!-- Validācija -->
                    <TextBlock x:Name="txtSaveMappingValidation"
                       Foreground="Red"
                       Visibility="Collapsed"
                       Margin="0,0,0,15"/>

                    <!-- Pogas -->
                    <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center">

                        <Button Content="Save"
                        Width="100"
                        Margin="5"
                        Click="SaveMapping_Click"/>

                        <Button Content="Cancel"
                        Width="100"
                        Margin="5"
                        Click="CancelSaveMapping_Click"/>

                    </StackPanel>

                </StackPanel>

            </Border>

        </Grid>
        <Grid x:Name="HeaderRowOverlay"
      Background="#AA000000"
      Visibility="Collapsed">

            <Border Width="320"
            Padding="25"
            Background="White"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">

                <StackPanel>

                    <TextBlock Text="Select Header Row"
                       FontSize="22"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20"/>

                    <ComboBox x:Name="CbHeaderRowOverlay"
                      Height="30"
                      SelectionChanged="CbHeaderRowOverlay_SelectionChanged"/>

                    <Button Content="Skip"
                    Width="100"
                    Margin="0,20,0,0"
                    HorizontalAlignment="Center"
                    Click="SkipHeaderRow_Click"/>

                </StackPanel>

            </Border>

        </Grid>
    </Grid>
    
</Window>
