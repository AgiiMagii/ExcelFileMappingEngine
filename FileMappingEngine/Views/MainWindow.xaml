<Window x:Class="FileMappingEngine.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FileMappingEngine"
        mc:Ignorable="d"
        Title="File Mapper" Height="500" Width="1000"
        Loaded="Window_Loaded">
    <Grid>
        <DockPanel LastChildFill="True">
            <StackPanel x:Name="mappingPanel" Width="80"/>
            <ToolBar DockPanel.Dock="Top" Height="41" Padding="5">
                <TextBox Name="txtFilePath" HorizontalAlignment="Left" TextWrapping="Wrap" Text="Choose File" VerticalAlignment="Top" Width="200"/>
                <Button Name="chooseFileButton" Content="Open File" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="5,0,20,0" Click="chooseFileButton_Click"/>
                <StackPanel Name="headerRowPanel" Orientation="Horizontal" VerticalAlignment="Top" IsEnabled="False">
                    <Label Content="Header row"/>
                    <ComboBox Name="cbHeaderRow" Margin="5,0,0,0" Width="40" SelectionChanged="cbHeaderRow_SelectionChanged"/>
                </StackPanel>
                <Button Name="saveFileButton" Content="Save File" VerticalAlignment="Top" Margin="20,0,20,0" Click="saveFileButton_Click"/>
                <Button Name="saveMapping" Content="Save new mapping set" VerticalAlignment="Top" Margin="20,0,20,0" Click="SaveMappingSet_Click"/>
                <Button Name="resetTable" Content="Reset Table" VerticalAlignment="Top" Margin="20,0,20,0" Click="ResetTable_Click"/>
                <Button Name="undo" Content="Undo" VerticalAlignment="Top" Margin="20,0,20,0" Click="Undo_Click"/>

            </ToolBar>
            <Grid>
                <DataGrid Name="dataGrid"
                  AutoGenerateColumns="True"
                  HeadersVisibility="Column"
                  Margin="5"
                  Sorting="dataGrid_Sorting"
                  AutoGeneratingColumn="dataGrid_AutoGeneratingColumn"/>
            </Grid>
        </DockPanel>
        <Grid x:Name="RenameColumnOverlay"
      Background="#AA000000"
      Visibility="Collapsed">

            <Border HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Padding="30"
            Background="White"
            Width="450">

                <StackPanel>

                    <!-- Virsraksts -->
                    <TextBlock Text="Rename Column"
                       FontSize="24"
                       FontWeight="Bold"
                       Margin="0,0,0,20"
                       HorizontalAlignment="Center"/>

                    <!-- Pašreizējais nosaukums -->
                    <TextBlock Text="Current column name:"
                       Margin="0,0,0,5"/>

                    <TextBlock x:Name="txtCurrentColumnName"
                       FontWeight="Bold"
                       Margin="0,0,0,20"/>

                    <!-- Jaunais nosaukums -->
                    <TextBlock Text="New column name:"
                       Margin="0,0,0,5"/>

                    <TextBox x:Name="txtNewColumnName"
                     Height="30"
                     Margin="0,0,0,10"/>

                    <!-- Validācijas teksts -->
                    <TextBlock x:Name="txtRenameValidation"
                       Foreground="Red"
                       Visibility="Collapsed"
                       Margin="0,0,0,15"/>

                    <!-- Pogas -->
                    <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center">

                        <Button Content="Save"
                        Width="100"
                        Margin="5"
                        Click="SaveRenameColumn_Click"/>

                        <Button Content="Cancel"
                        Width="100"
                        Margin="5"
                        Click="CancelRenameColumn_Click"/>

                    </StackPanel>

                </StackPanel>

            </Border>

        </Grid>
        <Grid x:Name="MergeColumnsOverlay"
      Background="#AA000000"
      Visibility="Collapsed">

            <Border HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Padding="30"
            Background="White"
            Width="450">

                <StackPanel>

                    <!-- Virsraksts -->
                    <TextBlock Text="Merge Columns"
                       FontSize="24"
                       FontWeight="Bold"
                       Margin="0,0,0,20"
                       HorizontalAlignment="Center"/>

                    <!-- Pirmā kolonna -->
                    <TextBlock Text="First column:"
                       Margin="0,0,0,5"/>

                    <ComboBox x:Name="cmbMergeColumn1"
                      Height="30"
                      Margin="0,0,0,15"/>

                    <!-- Atdalītājs -->
                    <TextBlock Text="Separator:"
                       Margin="0,0,0,5"/>

                    <TextBox x:Name="txtMergeSeparator"
                     Height="30"
                     Margin="0,0,0,15"
                     Text=" "/>

                    <!-- Otrā kolonna -->
                    <TextBlock Text="Second column:"
                       Margin="0,0,0,5"/>

                    <ComboBox x:Name="cmbMergeColumn2"
                      Height="30"
                      Margin="0,0,0,15"/>

                    <!-- Jaunās kolonnas nosaukums -->
                    <TextBlock Text="Result column name:"
                       Margin="0,0,0,5"/>

                    <TextBox x:Name="txtMergeResultColumn"
                     Height="30"
                     Margin="0,0,0,10"/>

                    <!-- Validācijas teksts -->
                    <TextBlock x:Name="txtMergeValidation"
                       Foreground="Red"
                       Visibility="Collapsed"
                       Margin="0,0,0,15"/>

                    <!-- Pogas -->
                    <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center">

                        <Button Content="Save"
                        Width="100"
                        Margin="5"
                        Click="SaveMergeColumns_Click"/>

                        <Button Content="Cancel"
                        Width="100"
                        Margin="5"
                        Click="CancelMergeColumns_Click"/>

                    </StackPanel>

                </StackPanel>

            </Border>

        </Grid>
    </Grid>
    
</Window>
